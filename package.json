{
  "name": "cc-hub",
  "version": "0.1.0",
  "description": "TUI for managing Claude Code model configurations",
  "type": "module",
  "bin": {
    "cc-hub": "dist/cli.js"
  },
  "scripts": {
    "dev": "pnpm run build && pnpm start",
    "dev:watch": "nodemon --watch src --ext ts,tsx --exec 'pnpm run build && pnpm start'",
    "build": "node build.mjs",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "ink": "^6.0.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "json5": "^2.2.3",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/json5": "^2.2.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT",
  "keywords": [
    "claude",
    "claude-code",
    "llm",
    "tui"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slashspace/cc-hub.git"
  },
  "files": [
    "dist"
  ]
}
